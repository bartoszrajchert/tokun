{
  "name": "tokun-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "examples"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "release": "turbo run build lint test && changeset publish",
    "version": "changeset version",
    "test": "turbo test",
    "typedoc": "turbo typedoc"
  },
  "author": "Bartosz Rajchert",
  "license": "MIT",
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@vitest/coverage-v8": "^4.1.3",
    "prettier": "^3.4.2",
    "prettier-plugin-organize-imports": "^4.1.0",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "turbo": "^2.8.20",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.3"
  },
  "overrides": {
    "@babel/runtime": "7.26.10",
    "ajv": "6.14.0",
    "brace-expansion": "1.1.13",
    "flatted": "3.4.2",
    "glob": "10.5.0",
    "js-yaml": "3.14.2",
    "mdast-util-to-hast": "13.2.1",
    "minimatch": "3.1.4",
    "picomatch": "2.3.2",
    "yaml": "2.8.3"
  },
  "packageManager": "bun@1.3.10",
  "engines": {
    "node": ">=18"
  }
}
