{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "test": {},
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["typedoc", "^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "out/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typedoc": {
      "outputs": ["app/docs/content/api/**"]
    },
    "docs#typedoc": {
      "outputs": ["app/docs/content/api/**"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/apps/www/typedoc.json",
        "$TURBO_ROOT$/apps/www/scripts/typedoc/**",
        "$TURBO_ROOT$/packages/tokun/src/**",
        "$TURBO_ROOT$/packages/tokun/typedoc.json",
        "$TURBO_ROOT$/packages/tokun/package.json"
      ]
    },
    "docs#dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["typedoc"]
    }
  }
}
