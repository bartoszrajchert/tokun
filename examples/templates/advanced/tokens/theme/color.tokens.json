{
  "brand": {
    "color": {
      "$type": "color",
      "primary": {
        "$value": {
          "colorSpace": "srgb",
          "components": [0, 0.3412, 1],
          "hex": "#0057FF"
        },
        "$description": "Primary brand color"
      },
      "secondary": {
        "$value": {
          "colorSpace": "srgb",
          "components": [1, 0.8431, 0],
          "hex": "#FFD700"
        },
        "$type": "color",
        "$description": "Secondary brand color"
      },
      "neutral": {
        "light": {
          "$value": {
            "colorSpace": "srgb",
            "components": [0.9608, 0.9608, 0.9608],
            "hex": "#F5F5F5"
          },
          "$type": "color",
          "$description": "Light neutral color"
        },
        "dark": {
          "$value": {
            "colorSpace": "srgb",
            "components": [0.2, 0.2, 0.2],
            "hex": "#333333"
          },
          "$type": "color",
          "$description": "Dark neutral color"
        }
      }
    }
  },
  "alias": {
    "color": {
      "background": {
        "primary": {
          "$value": "{brand.color.primary}",
          "$type": "color",
          "$description": "Primary background color"
        },
        "secondary": {
          "$value": "{brand.color.secondary}",
          "$type": "color",
          "$description": "Secondary background color"
        },
        "neutral": {
          "light": {
            "$value": "{brand.color.neutral.light}",
            "$type": "color",
            "$description": "Light neutral background color"
          },
          "dark": {
            "$value": "{brand.color.neutral.dark}",
            "$type": "color",
            "$description": "Dark neutral background color"
          }
        }
      },
      "text": {
        "primary": {
          "$value": "{brand.color.neutral.dark}",
          "$type": "color",
          "$description": "Primary text color"
        },
        "secondary": {
          "$value": "{brand.color.neutral.light}",
          "$type": "color",
          "$description": "Secondary text color"
        }
      }
    }
  }
}
